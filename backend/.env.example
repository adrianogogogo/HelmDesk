# Template de variáveis de ambiente do backend RelmDesk.
# Copie para backend/.env e preencha com os valores REAIS.
# NUNCA commite o arquivo .env (ele está no .gitignore).

NODE_ENV=production
PORT=5000

# --- Banco de dados PostgreSQL ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=relmdesk
DB_USER=relmdesk_user
DB_PASSWORD=SUBSTITUA_PELA_SENHA_REAL_DO_BANCO

# --- Autenticação (JWT) ---
# Gere um segredo forte e único, ex.: openssl rand -hex 32
JWT_SECRET=SUBSTITUA_POR_UM_SEGREDO_FORTE_E_UNICO
JWT_EXPIRES_IN=8h
JWT_REMEMBER_EXPIRES=30d

# --- URLs da aplicação ---
FRONTEND_URL=http://SEU_HOST:3000
APP_URL=http://SEU_HOST:3000

# --- Upload ---
MAX_FILE_SIZE=15728640

# --- SMTP (e-mail) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
